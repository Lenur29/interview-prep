{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "preview": {
      "cache": false,
      "persistent": true
    },
    "type-check": {
      "dependsOn": ["^type-check"],
      "outputs": [],
      "cache": true
    },
    "codegen": {
      "outputs": ["src/types.ts"],
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": [],
    },
    "icons": {
      "outputs": ["src/assets/icons/index.ts"],
      "cache": true
    },
    "langs": {
      "outputs": [],
      "cache": false
    },
    "test:e2e": {
      "outputs": ["playwright-report/**", "test-results/**"],
      "cache": false
    }
  }
}
