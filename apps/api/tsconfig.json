{
  "extends": "../../tsconfig.node.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": "./",
    "rootDir": "./src",
    "removeComments": true,
    "paths": {
      "@/*": ["src/*"],
      "@lm/permissions": ["../../libs/permissions/src"],
      "@lm/permissions/*": ["../../libs/permissions/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
