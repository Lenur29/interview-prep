{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "entryFile": "main.js",
  "compilerOptions": {
    "deleteOutDir": true,
    "builder": "swc",
    "typeCheck": true,
    "assets": [
      {
        "include": "resources/emails/**/*.hbs",
        "watchAssets": true
      }
    ],
    "plugins": []
  },
  "generateOptions": {
    "spec": false
  }
}
